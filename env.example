# Shared JWT secret used by gateway, auth, chat and routes services.
JWT_SHARED_SECRET=cambiar_por_secreto_seguro

# Frontend and gateway
FRONTEND_URL=http://localhost:5173
VITE_API_URL=http://localhost:5173
COOKIE_MAX_AGE=1800

# Auth service
ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_ALGORITHM=HS256
AUTH_DEBUG=False
AUTH_ENVIRONMENT=production

# PostgreSQL
POSTGRES_DB=loggeo_base_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_PORT=5432

# MongoDB
MONGO_PORT=27017
