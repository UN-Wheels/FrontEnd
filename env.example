# ── Frontend (Next.js) ────────────────────────────────────────────────────────
# URL del API Gateway — único punto de entrada para REST y Socket.IO
NEXT_PUBLIC_API_URL=http://localhost:8080

# ── Gateway / Servicios ───────────────────────────────────────────────────────
JWT_SHARED_SECRET=cambiar_por_secreto_seguro
FRONTEND_URL=http://localhost:3000
COOKIE_MAX_AGE=1800

# ── Auth service ──────────────────────────────────────────────────────────────
ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_ALGORITHM=HS256
AUTH_DEBUG=False
AUTH_ENVIRONMENT=production

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_DB=loggeo_base_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_PORT=5432

# ── MongoDB ───────────────────────────────────────────────────────────────────
MONGO_PORT=27017
