# ── Stack completo (docker compose desde /FrontEnd) ──────────────────────────
# Copia este archivo como `FrontEnd/.env`.

# Shared JWT secret usado por gateway, auth, chat y routes.
JWT_SHARED_SECRET=cambiar_por_secreto_seguro

# Frontend
FRONTEND_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:8080

# Gateway
COOKIE_MAX_AGE=1800

# Auth service
ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_ALGORITHM=HS256
AUTH_DEBUG=False
AUTH_ENVIRONMENT=production

# PostgreSQL
POSTGRES_DB=loggeo_base_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_PORT=5432

NEON_AUTH_DB_URL1=postgresql://neondb_owner:npg_2s8zRULukSYI@ep-small-tooth-apkq7bfj-pooler.c-7.us-east-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require
NEON_AUTH_DB_URL2=postgresql://neondb_owner:npg_2s8zRULukSYI@ep-small-tooth-apkq7bfj-pooler.c-7.us-east-1.aws.neon.tech/neondb-replica?sslmode=require&channel_binding=require
NEON_AUTH_DB_URL3=postgresql://neondb_owner:npg_2s8zRULukSYI@ep-small-tooth-apkq7bfj-pooler.c-7.us-east-1.aws.neon.tech/neondb-replica2?sslmode=require&channel_binding=require

# MongoDB
MONGO_PORT=27017
